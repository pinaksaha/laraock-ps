# Compose project name (used as a prefix for containers, networks, volumes)
COMPOSE_PROJECT_NAME=laravel-stack

# PHP version baked into the php-fpm image
PHP_VERSION=8.3

# Local user mapping so files written from inside the container
# stay owned by your host user (run `id -u` / `id -g` to verify).
UID=1000
GID=1000

# Where your Laravel apps live, relative to the docker/ directory.
# Each subfolder is a Laravel app, e.g. apps/app1, apps/app2.
APPS_PATH=../apps

# ---- nginx -----------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ---- MySQL -----------------------------------------------------------------
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=secret
MYSQL_DATABASE=laravel
MYSQL_USER=laravel
MYSQL_PASSWORD=secret
# Comma-separated list of additional databases to create on first boot,
# each granted to MYSQL_USER. Example: app1,app2,reporting
MYSQL_MULTIPLE_DATABASES=app1,app2

# ---- Redis -----------------------------------------------------------------
REDIS_PORT=6379

# ---- Optional workers profile ---------------------------------------------
# Used only when you start with `--profile workers`.
QUEUE_APP_DIR=app1
SCHEDULER_APP_DIR=app1

# ---- Optional tools profile -----------------------------------------------
PMA_PORT=8080
